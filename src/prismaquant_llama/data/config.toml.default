# prismaquant-llama configuration.
#
# This file lives at ~/.prismaquant-llama/config.toml. It is auto-installed
# from the shipped default the first time you invoke the tool. After that,
# edit this file by hand to change defaults — there is no `setup` subcommand.
#
# Every key here can be overridden per-run by a CLI flag of the same name
# (with underscores replaced by dashes, e.g. ppl_chunks → --ppl-chunks).
# CLI flags ALWAYS win. Missing keys fall through to built-in defaults.
#
# To use a different config file for a single run, pass `--config /path/to/other.toml`.
# That can be useful if you maintain separate configs for separate llama.cpp
# binary builds (e.g., one mainline, one fork) — point each config's `base`
# and `path` at the appropriate directories.
#
# TOML reminders:
#   - strings need quotes:  priority = "111"   (not 111)
#   - lists use brackets:   quants = ["Q4_K", "Q5_K"]
#   - paths can use ~:      base = "~/quants"
#   - empty strings ("") mean "use the built-in default"


[prismaquant-llama]

# ──────────────────────────────────────────────────────────────────────────────
# base — working directory for downloads, intermediates, calibration data,
# and final GGUFs.
#
# Layout under base:
#   _shared/
#     hf-cache/      ← downloaded HuggingFace safetensors
#     bf16/          ← BF16 GGUFs converted from safetensors
#     imatrix-cache/ ← imatrix files (one per (model, corpus, chunks) tuple)
#     probe/         ← prismaquant Hessian probe artifacts
#   ppl-corpus/      ← downloaded PPL calibration corpora (when URL given)
#   imatrix-corpus/  ← downloaded imatrix calibration corpora (when URL given)
#   calibration/
#     system.json    ← written by `prismaquant-llama calibrate system <input>`
#     models/<model>.json  ← written by `prismaquant-llama calibrate model <input>`
#   ggufs/           ← final prismaquant GGUFs
#   work/<run>/      ← per-run scratch (recipes, costs, logs)
#
# Override per-run with `--base /some/path`.
# ──────────────────────────────────────────────────────────────────────────────
base = "~/.prismaquant-llama/"


# ──────────────────────────────────────────────────────────────────────────────
# path — directory containing the llama-quantize, llama-quantize-cost,
# llama-perplexity, and llama-bench binaries.
#
# Empty string ("") means "discover via $PATH" — the same way `llama-quantize`
# resolves at the shell. Set to a specific directory if your binaries aren't
# on $PATH, e.g. "/opt/llama/bin" or "/home/me/llama.cpp/build/bin".
#
# `llama-quantize-cost` is a custom binary not in mainline llama.cpp; build
# it from the source vendored at src/pipeline/cpp/quantize-cost/ and place
# it next to llama-quantize. See the README for the recipe.
#
# Override per-run with `--path /opt/llama/bin`.
# ──────────────────────────────────────────────────────────────────────────────
path = ""


# ──────────────────────────────────────────────────────────────────────────────
# quants — the allowed weight-quant whitelist passed to the allocator and to
# `llama-quantize-cost`. The allocator picks one format per tensor from this
# list, minimizing predicted Δloss under the size budget.
#
# DEFAULT BELOW: mainline llama.cpp formats only. If you use a fork that adds
# extra quants (ik_llama, frankenturbo, etc.), append them here by hand —
# e.g. add "IQ4_K", "IQ4_KS", "IQ4_KSS", "IQ3_K", "IQ3_KS" for ik_llama.
# Run `llama-quantize --help` against your binary to see what's available.
#
# 2-bit-and-under formats are intentionally excluded — they're a documented
# PPL cliff on most architectures. Add them back here if you specifically
# want extreme compression.
#
# BF16 is included so the allocator has a full-precision option for the most
# sensitivity-critical tensors when budget allows. At 25% budget it's never
# picked (4× too expensive); at higher budgets (50%+) it becomes a real
# quality knob.
#
# If you run MoE models (gpt-oss, Qwen-MoE, Mixtral, etc.), append
# "MXFP4_MOE" — mainline-supported FP4 micro-scaled format for MoE expert
# tensors specifically.
#
# Override per-run with `--quants Q4_K,Q5_K,...`.
# ──────────────────────────────────────────────────────────────────────────────
quants = [
    "Q3_K",
    "Q4_K",
    "Q5_K",
    "Q6_K",
    "Q8_0",
    "IQ3_XXS",
    "IQ3_XS",
    "IQ3_S",
    "IQ3_M",
    "IQ4_XS",
    "IQ4_NL",
    "BF16",
]


# ──────────────────────────────────────────────────────────────────────────────
# reference_format — "bf16" (default) or "f16". Controls Stage B's GGUF
# conversion outtype AND the calibration's reference for Δppl / pp/tg ratio
# computation. The corresponding entry must appear in the `quants` list above
# (use "BF16" with reference_format="bf16", "F16" with reference_format="f16");
# the calibrator auto-adds the reference if absent.
#
# When to set "f16": on backends whose hipblas / GEMM library lacks BF16
# kernels for some shapes — notably gfx1102 / gfx1103 ROCm (RDNA3 navi33/32)
# under stock ROCm + Tensile. Symptom: Stage D imatrix or the BF16 ppl run
# crashes with `CUBLAS_STATUS_INTERNAL_ERROR` on a hipblasGemmEx call with
# `HIP_R_16BF` arguments. F16 GEMM kernels (`HIP_R_16F`) are well-supported
# on the same hardware. Output JSON field names (ppl_delta_vs_f16,
# pp_ratio_vs_bf16, tg_ratio_vs_bf16) keep their legacy names regardless;
# semantically they're "delta vs the configured reference."
#
# Caveat: F16 has narrower dynamic range than BF16 (5-bit vs 8-bit exponent).
# For most modern LLM weights this is a non-issue (Qwen, Llama, Phi, etc.);
# models with extreme RMS norms (some Mistral checkpoints) can saturate F16.
# ──────────────────────────────────────────────────────────────────────────────
reference_format = "bf16"


# ──────────────────────────────────────────────────────────────────────────────
# mtp_format — format to assign to MTP / NEXTN tensors (multi-token-prediction
# head, present in Qwen3.5/3.6 and similar models). Only takes effect when
# the source model declares num_nextn_predict_layers > 0; otherwise the
# allocator's normal solve picks the format and this key is unused.
#
# Why a per-MTP override exists: speculative-decode acceptance rates are
# disproportionately sensitive to MTP-tensor quantization, and the
# acceptance impact has not been measured for sub-BF16 MTP weights. Until
# that's validated for your inference stack, keep MTP at BF16. Once you
# have measurements showing acceptable acceptance under e.g. Q8_0 MTP,
# set this to that format and re-run.
#
# Any format name in `quants` (or BF16) is accepted.
# ──────────────────────────────────────────────────────────────────────────────
mtp_format = "BF16"


# ──────────────────────────────────────────────────────────────────────────────
# budget — target final GGUF size as a percentage of the BF16 GGUF size.
# Reference points (approximate, model-dependent):
#   - Q8_0    → ~50%
#   - Q6_K    → ~38%
#   - Q5_K_M  → ~33%
#   - Q4_K_M  → ~28%
#   - IQ4_XS  → ~27%
#   - Q3_K_L  → ~22%
#
# Default 25 sits slightly tighter than IQ4_XS — usable middle ground for
# most production deployments.
#
# Override per-run with `--budget 30`.
# ──────────────────────────────────────────────────────────────────────────────
budget = 25


# ──────────────────────────────────────────────────────────────────────────────
# priority — three-digit ratio of PPL / TG / PP weights for the allocator's
# multi-objective scoring.
#
#   - X = PPL quality weight  (digit 0–9)
#   - Y = TG (token generation) speed weight  (digit 0–9)
#   - Z = PP (prompt processing) speed weight  (digit 0–9)
#
# Only the relative ratios matter, so "111" and "333" and "999" all behave
# identically (all equal-weight). "522" and "311" are also equivalent (PPL-heavy).
#
# Common combos:
#   "111" — equal weight, balanced (default)
#   "522" — quality-first
#   "252" — token-generation-first (chat / streaming)
#   "225" — prompt-processing-first (long-context)
#   "900" — pure PPL, ignore speed
#
# Override per-run with `--priority 522`.
# ──────────────────────────────────────────────────────────────────────────────
priority = "111"


# ──────────────────────────────────────────────────────────────────────────────
# ppl_corpus — corpus used by llama-perplexity passes (calibration runs and
# the final post-quantize PPL eval).
#
# Three input forms:
#   ""              → use the bundled wikitext-2-raw test split (~1.3 MB).
#                     Industry-standard llama.cpp PPL benchmark; gives values
#                     directly comparable to other llama.cpp PPL numbers.
#   "/some/path"    → use this on-disk text file. Never auto-deleted.
#   "https://..."   → download to {base}/ppl-corpus/ on first use, then
#                     cache. Subject to --purge cleanup.
#
# Override per-run with `--ppl-corpus /path/or/url`.
# ──────────────────────────────────────────────────────────────────────────────
ppl_corpus = ""


# ──────────────────────────────────────────────────────────────────────────────
# imatrix_corpus — corpus used by llama-imatrix to generate the importance
# matrix consumed at quantize time. Different role from ppl_corpus —
# imatrix wants diverse semantic content to surface activation distributions,
# while PPL wants a clean reference text.
#
# Same three input forms as ppl_corpus:
#   ""              → bundled bartowski-imatrix-v5-semantic (~1.5 MB).
#                     Public compilation by bartowski; widely used as the
#                     de-facto starter imatrix corpus.
#   "/some/path"    → on-disk text file. Never auto-deleted.
#   "https://..."   → download to {base}/imatrix-corpus/ on first use.
#                     Subject to --purge cleanup.
#
# Override per-run with `--imatrix-corpus /path/or/url`.
# ──────────────────────────────────────────────────────────────────────────────
imatrix_corpus = ""


# ──────────────────────────────────────────────────────────────────────────────
# ppl_chunks — number of chunks fed to llama-perplexity per evaluation.
# Higher values give a tighter PPL stderr (better confidence in the measured
# quality numbers) at proportional cost in wall time.
#
# Approximate stderr at default 50 chunks: ±0.09 PPL. Doubling chunks
# narrows stderr roughly by sqrt(2). Production-grade calibration typically
# uses 100–200 chunks; 50 is a reasonable balanced default.
#
# Override per-run with `--ppl-chunks 100`.
# ──────────────────────────────────────────────────────────────────────────────
ppl_chunks = 50


# ──────────────────────────────────────────────────────────────────────────────
# imatrix_chunks — number of chunks consumed by llama-imatrix when generating
# the importance matrix. Higher = better activation-distribution coverage =
# higher-quality imatrix = better quantize results, again at proportional
# wall-time cost.
#
# Mainline llama.cpp guidance suggests 100–200 chunks for serious imatrix
# generation. The default 50 here is a balanced starter — bump it up
# (especially toward 200) for production-grade quants.
#
# Override per-run with `--imatrix-chunks 200`.
# ──────────────────────────────────────────────────────────────────────────────
imatrix_chunks = 50


# ──────────────────────────────────────────────────────────────────────────────
# convert_script — path to llama.cpp's `convert_hf_to_gguf.py` (used by
# Stage B to convert HuggingFace safetensors to BF16 GGUF).
#
# This script is NOT installed by `cmake --install` / `make install` — it
# stays at the root of your llama.cpp source tree. We try to find it
# automatically by walking up two levels from `path` (works for
# `<repo>/build/bin/llama-quantize` → `<repo>/convert_hf_to_gguf.py`),
# checking next to the binary, then $PATH. If your install puts the
# script somewhere unusual, set this key explicitly.
#
# Empty string ("") means auto-discover.
#
# Override per-run with `--convert-script /path/to/convert_hf_to_gguf.py`.
# ──────────────────────────────────────────────────────────────────────────────
convert_script = ""


# ──────────────────────────────────────────────────────────────────────────────
# libs — extra directory prepended to LD_LIBRARY_PATH for every subprocess
# call we make (llama-quantize, llama-imatrix, llama-perplexity, llama-bench,
# llama-quantize-cost, convert_hf_to_gguf.py, the bundled allocator scripts).
#
# Set this if your llama.cpp binaries depend on a libllama.so / libggml.so
# that isn't on your system loader path — for example, if you built
# llama.cpp with shared libs at `<fork>/build/src/` and your binaries at
# `<fork>/build/bin/` need to find them at runtime.
#
# Empty string ("") means no override (system LD_LIBRARY_PATH is used as-is).
#
# Override per-run with `--libs /path/to/llama-libs`.
# ──────────────────────────────────────────────────────────────────────────────
libs = ""


# ──────────────────────────────────────────────────────────────────────────────
# [precondition] — Stage F+, between G (allocator) and H (quantize).
#
# F+ applies activation-aware pre-conditioning passes (currently: AWQ channel
# rescale) to BF16 weights of tensors whose allocator-chosen format is at or
# above `bpw_floor`. The literal "disable below 4 bits" caveat falls out of
# the threshold: tensors that landed at IQ3 / Q3 / Q2 / etc. pass through
# unchanged.
#
# CURRENT PHASE: P2 (AWQ) shipped. P3 (GPTQ on top of AWQ) was prototyped
# 2026-05-11 and shelved — the simulator-grid mismatch vs llama-quantize's
# k-quant codebook caused a net PPL regression (+10.5% on Qwen3.5-4B PQ32-111).
# See ~/kernel-work/prismaquant-llama-docs/preconditioning-p3-result.md.
# The gptq_apply pure-math primitive is preserved at scripts/gptq_apply.py
# for a future revival with a k-quant-aware simulator. P4 (scale-sweep) and
# P5 (HALO) are also future work.
#
# CLI overrides: `--precondition off|awq`, `--precondition-bpw-floor 4.0`.
# ──────────────────────────────────────────────────────────────────────────────
[precondition]

# mode — which method stack runs in Stage F+.
#   "off"   (default) skip Stage F+ entirely (pc-bf16 == source bf16).
#   "awq"   AWQ proper-fold pass (P2): per-input-channel scale with γ-fold
#           into the predecessor RMSNorm. Mathematically identity-preserving;
#           redistributes weight magnitudes favorably for group-quantizers.
mode = "off"

# bpw_floor — chosen-format bits-per-weight below which F+ skips the tensor.
# Default 4.0 is the literal "disable below 4 bits" cutoff. Bump to 4.5 to
# exclude IQ4_XS (~4.25 bpw); drop to 3.5 if you want Q3_K to benefit too.
bpw_floor = 4.0
